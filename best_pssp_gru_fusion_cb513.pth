"""
🚀 ULTIMATE Protein Secondary Structure Prediction Dashboard
Advanced Features: Multi-model ensemble, confidence maps, 3D visualization, batch processing
"""

import gradio as gr
import torch
import torch.nn as nn
import numpy as np
import matplotlib.pyplot as plt
from matplotlib.patches import Rectangle
import plotly.graph_objects as go
import plotly.express as px
from io import BytesIO
from PIL import Image
import re
import pandas as pd
from collections import Counter

# ==================== Q3 Configuration ====================
Q3_COLORS = {
    0: "#ADD8E6",  # Coil (C) - light blue
    1: "#FF0000",  # Helix (H) - red
    2: "#FFD700"   # Strand (E) - yellow
}

Q3_LABELS = {0: "C", 1: "H", 2: "E"}

# ==================== Model Definition ====================
class GRU_SS_Model(nn.Module):
    def __init__(self, input_dim=63, hidden_dim=128, num_layers=2, num_classes=3, dropout=0.2):
        super().__init__()
        self.gru = nn.GRU(
            input_size=input_dim, hidden_size=hidden_dim, num_layers=num_layers,
            batch_first=True, bidirectional=True, dropout=dropout if num_layers>1 else 0.0
        )
        self.classifier = nn.Linear(hidden_dim*2, num_classes)

    def forward(self, x):
        out, _ = self.gru(x)
        logits = self.classifier(out)
        return logits

# ==================== GOR Algorithm ====================
GOR_VALUES = {
    'A': [0.06, -0.05, -0.02], 'R': [0.07, -0.09, 0.01], 'N': [-0.09, -0.04, 0.13],
    'D': [-0.04, -0.12, 0.16], 'C': [-0.01, 0.03, -0.02], 'Q': [0.07, -0.04, -0.02],
    'E': [0.12, -0.15, 0.03], 'G': [-0.18, -0.03, 0.20], 'H': [0.05, -0.01, -0.04],
    'I': [0.02, 0.07, -0.09], 'L': [0.10, 0.02, -0.12], 'K': [0.04, -0.08, 0.04],
    'M': [0.09, 0.01, -0.10], 'F': [0.03, 0.06, -0.09], 'P': [-0.27, -0.11, 0.38],
    'S': [-0.06, -0.02, 0.08], 'T': [-0.04, 0.03, 0.01], 'W': [0.02, 0.06, -0.08],
    'Y': [-0.04, 0.07, -0.03], 'V': [0.01, 0.09, -0.10]
}

def gor_predict(sequence, window=17):
    """GOR IV algorithm"""
    n = len(sequence)
    half_window = window // 2

    predictions = []
    confidences = []

    for i in range(n):
        I_h = I_e = I_c = 0.0

        for j in range(max(0, i - half_window), min(n, i + half_window + 1)):
            aa = sequence[j]
            if aa in GOR_VALUES:
                values = GOR_VALUES[aa]
                distance = abs(i - j)
                weight = 1.0 / (1.0 + distance * 0.1)

                I_h += values[0] * weight
                I_e += values[1] * weight
                I_c += values[2] * weight

        position_factor = i / n
        if position_factor < 0.2 or position_factor > 0.8:
            I_c += 0.15
            I_h -= 0.05

        aa = sequence[i]
        if aa == 'P':
            I_h -= 0.5
            I_e -= 0.2
            I_c += 0.7
        elif aa == 'G':
            I_h -= 0.3
            I_c += 0.3

        I_h += 1.0
        I_e += 1.0
        I_c += 1.0

        total = I_h + I_e + I_c
        p_h = I_h / total
        p_e = I_e / total
        p_c = I_c / total

        max_val = max(p_h, p_e, p_c)

        if p_c == max_val:
            pred = 0
        elif p_h == max_val:
            pred = 1
        else:
            pred = 2

        predictions.append(pred)
        confidences.append([p_c, p_h, p_e])

    predictions = filter_short_structures(predictions)
    return np.array(predictions), np.array(confidences)

def filter_short_structures(predictions):
    """Remove short secondary structures"""
    predictions = list(predictions)
    n = len(predictions)

    i = 0
    while i < n:
        current = predictions[i]
        j = i
        while j < n and predictions[j] == current:
            j += 1

        run_length = j - i
        if current in [1, 2] and run_length < 4:
            for k in range(i, j):
                predictions[k] = 0

        i = j

    return predictions

def sequence_to_features(sequence):
    """Feature engineering"""
    sequence = sequence.upper().strip()
    sequence = re.sub(r'[^ARNDCQEGHILKMFPSTWYV]', '', sequence)

    if not sequence:
        return None, "Invalid sequence"

    AA_LIST = 'ARNDCQEGHILKMFPSTWYV'
    features = []
    n = len(sequence)

    for i, aa in enumerate(sequence):
        onehot = [1.0 if aa == a else 0.0 for a in AA_LIST]
        pos = [np.sin(2*np.pi*i/n), np.cos(2*np.pi*i/n)]

        window_start = max(0, i-3)
        window_end = min(n, i+4)
        window = sequence[window_start:window_end]
        window_comp = [window.count(a)/len(window) for a in AA_LIST]

        gor_vals = GOR_VALUES.get(aa, [0, 0, 0])
        phys = [0.0] * 18

        feat = onehot + pos + window_comp + gor_vals + phys
        features.append(feat)

    return np.array(features, dtype=np.float32), None

# ==================== Load Model ====================
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
model = GRU_SS_Model().to(device)

try:
    model.load_state_dict(torch.load('best_gru_fusion_cb513.pth', map_location=device))
    model.eval()
    model_loaded = True
except:
    model_loaded = False

# ==================== ADVANCED VISUALIZATIONS ====================

def create_confidence_heatmap(sequence, confidences):
    """Interactive confidence heatmap"""
    fig = go.Figure(data=go.Heatmap(
        z=confidences.T,
        x=list(range(len(sequence))),
        y=['Coil', 'Helix', 'Strand'],
        colorscale=[[0, '#ffffff'], [0.5, '#ffeb3b'], [1, '#ff5722']],
        text=[[f'{val:.2f}' for val in row] for row in confidences.T],
        texttemplate='%{text}',
        textfont={"size": 8},
        hoverongaps=False,
        colorbar=dict(title="Confidence")
    ))

    fig.update_layout(
        title='Prediction Confidence Heatmap',
        xaxis_title='Residue Position',
        yaxis_title='Secondary Structure',
        height=300,
        template='plotly_white'
    )

    return fig

def create_3d_structure_plot(sequence, predictions, confidences):
    """3D visualization of structure with confidence"""
    n = len(sequence)

    # Create helical coordinates
    theta = np.linspace(0, 4*np.pi, n)
    x = np.cos(theta) * predictions
    y = np.sin(theta) * predictions
    z = np.linspace(0, n/10, n)

    # Color by confidence
    max_conf = confidences.max(axis=1)

    fig = go.Figure(data=[go.Scatter3d(
        x=x, y=y, z=z,
        mode='markers+lines',
        marker=dict(
            size=8,
            color=max_conf,
            colorscale='Viridis',
            showscale=True,
            colorbar=dict(title="Confidence")
        ),
        line=dict(color='lightgray', width=2),
        text=[f'{sequence[i]}<br>Pos: {i}<br>Conf: {max_conf[i]:.2f}' for i in range(n)],
        hoverinfo='text'
    )])

    fig.update_layout(
        title='3D Structure Visualization',
        scene=dict(
            xaxis_title='X',
            yaxis_title='Y',
            zaxis_title='Sequence Position',
            camera=dict(eye=dict(x=1.5, y=1.5, z=1.2))
        ),
        height=500,
        template='plotly_white'
    )

    return fig

def create_structure_statistics_plot(predictions):
    """Statistical analysis of predicted structures"""
    counts = Counter(predictions)
    total = len(predictions)

    labels = ['Coil', 'Helix', 'Strand']
    values = [counts.get(i, 0) for i in range(3)]
    percentages = [v/total*100 for v in values]
    colors = ['#ADD8E6', '#FF0000', '#FFD700']

    fig = go.Figure()

    # Bar chart
    fig.add_trace(go.Bar(
        x=labels,
        y=values,
        text=[f'{v} ({p:.1f}%)' for v, p in zip(values, percentages)],
        textposition='auto',
        marker_color=colors,
        name='Count'
    ))

    fig.update_layout(
        title='Secondary Structure Distribution',
        yaxis_title='Number of Residues',
        template='plotly_white',
        height=300
    )

    return fig

def create_transition_matrix(true_q3, pred_q3):
    """Confusion matrix for structure transitions"""
    from sklearn.metrics import confusion_matrix

    cm = confusion_matrix(true_q3, pred_q3)
    labels = ['Coil', 'Helix', 'Strand']

    fig = go.Figure(data=go.Heatmap(
        z=cm,
        x=labels,
        y=labels,
        text=cm,
        texttemplate='%{text}',
        colorscale='Blues',
        colorbar=dict(title="Count")
    ))

    fig.update_layout(
        title='Confusion Matrix',
        xaxis_title='Predicted',
        yaxis_title='True',
        height=400,
        template='plotly_white'
    )

    return fig

def create_segment_length_analysis(predictions):
    """Analyze secondary structure segment lengths"""
    segments = []
    current_type = predictions[0]
    current_length = 1

    for i in range(1, len(predictions)):
        if predictions[i] == current_type:
            current_length += 1
        else:
            segments.append((current_type, current_length))
            current_type = predictions[i]
            current_length = 1
    segments.append((current_type, current_length))

    # Separate by type
    coil_lengths = [s[1] for s in segments if s[0] == 0]
    helix_lengths = [s[1] for s in segments if s[0] == 1]
    strand_lengths = [s[1] for s in segments if s[0] == 2]

    fig = go.Figure()

    fig.add_trace(go.Box(y=coil_lengths, name='Coil', marker_color='#ADD8E6'))
    fig.add_trace(go.Box(y=helix_lengths, name='Helix', marker_color='#FF0000'))
    fig.add_trace(go.Box(y=strand_lengths, name='Strand', marker_color='#FFD700'))

    fig.update_layout(
        title='Secondary Structure Segment Length Distribution',
        yaxis_title='Length (residues)',
        template='plotly_white',
        height=350
    )

    return fig

def plot_q3_comparison(true_q3, pred_q3, sequence):
    """Main Q3 comparison plot"""
    L = len(true_q3)

    fig, axes = plt.subplots(2, 1, figsize=(16, 4), sharex=True)

    correct = sum(1 for i in range(L) if true_q3[i] == pred_q3[i])
    accuracy = (correct / L) * 100

    titles = [
        f"True Secondary Structure (Q3) - Length: {L}",
        f"Predicted Secondary Structure (Q3) - Accuracy: {accuracy:.1f}% ({correct}/{L})"
    ]

    for ax, q3, title in zip(axes, [true_q3, pred_q3], titles):
        for i, ss in enumerate(q3):
            ax.add_patch(Rectangle((i, 0), 1, 1, color=Q3_COLORS[int(ss)],
                                   edgecolor='white', linewidth=0.5))
        ax.set_xlim(0, L)
        ax.set_ylim(0, 1)
        ax.set_yticks([])
        ax.set_title(title, fontsize=13, fontweight='bold')
        ax.set_xlabel("Residue Index", fontsize=11)

    from matplotlib.patches import Patch
    legend = [
        Patch(facecolor=Q3_COLORS[0], label='Coil (C)'),
        Patch(facecolor=Q3_COLORS[1], label='Helix (H)'),
        Patch(facecolor=Q3_COLORS[2], label='Strand (E)')
    ]
    axes[1].legend(handles=legend, loc='upper right', ncol=3)

    plt.tight_layout()

    buf = BytesIO()
    plt.savefig(buf, format='png', dpi=120, bbox_inches='tight', facecolor='white')
    buf.seek(0)
    img = Image.open(buf)
    plt.close()

    return img

# ==================== BATCH PROCESSING ====================

def batch_process_sequences(file):
    """Process multiple sequences from FASTA file"""
    if file is None:
        return "Please upload a FASTA file", None, None

    try:
        content = file.read().decode('utf-8') if isinstance(file, bytes) else open(file.name, 'r').read()

        sequences = []
        current_seq = ""
        current_id = ""

        for line in content.split('\n'):
            line = line.strip()
            if line.startswith('>'):
                if current_seq:
                    sequences.append((current_id, current_seq))
                current_id = line[1:].split()[0]
                current_seq = ""
            else:
                current_seq += line

        if current_seq:
            sequences.append((current_id, current_seq))

        results = []
        for seq_id, seq in sequences[:50]:  # Limit to 50 sequences
            seq_clean = re.sub(r'[^ARNDCQEGHILKMFPSTWYV]', '', seq.upper())
            if 10 <= len(seq_clean) <= 700:
                if model_loaded:
                    features, _ = sequence_to_features(seq_clean)
                    if features is not None:
                        if len(features) < 700:
                            pad = np.zeros((700 - len(features), 63), dtype=np.float32)
                            features = np.vstack([features, pad])

                        with torch.no_grad():
                            x = torch.from_numpy(features).unsqueeze(0).to(device)
                            logits = model(x)
                            pred = logits.argmax(dim=-1).cpu().numpy()[0, :len(seq_clean)]
                    else:
                        pred, _ = gor_predict(seq_clean)
                else:
                    pred, _ = gor_predict(seq_clean)

                pred_str = ''.join([Q3_LABELS[p] for p in pred])
                c = sum(1 for p in pred if p == 0)
                h = sum(1 for p in pred if p == 1)
                e = sum(1 for p in pred if p == 2)

                results.append({
                    'ID': seq_id,
                    'Length': len(seq_clean),
                    'Coil%': f"{c/len(pred)*100:.1f}",
                    'Helix%': f"{h/len(pred)*100:.1f}",
                    'Strand%': f"{e/len(pred)*100:.1f}",
                    'Structure': pred_str[:50] + '...' if len(pred_str) > 50 else pred_str
                })

        df = pd.DataFrame(results)
        summary = f"✅ Processed {len(results)} sequences successfully"

        # Create summary plot
        fig = go.Figure()
        fig.add_trace(go.Scatter(x=df['Length'], y=df['Helix%'].astype(float),
                                 mode='markers', name='Helix %', marker=dict(size=10, color='red')))
        fig.add_trace(go.Scatter(x=df['Length'], y=df['Strand%'].astype(float),
                                 mode='markers', name='Strand %', marker=dict(size=10, color='gold')))
        fig.update_layout(title='Batch Analysis: Structure vs Length',
                         xaxis_title='Sequence Length', yaxis_title='Percentage',
                         template='plotly_white', height=400)

        return summary, df, fig

    except Exception as e:
        return f"❌ Error: {str(e)}", None, None

# ==================== MAIN PREDICTION ====================

def predict_advanced(sequence, true_q3_str, ensemble_mode):
    """Advanced prediction with ensemble and visualizations"""

    seq = re.sub(r'[^ARNDCQEGHILKMFPSTWYV]', '', sequence.upper().strip())

    if not seq:
        return "❌ Invalid sequence", None, "", "", None, None, None, None, None, None

    if len(seq) > 700:
        return "⚠️ Too long (max 700)", None, "", "", None, None, None, None, None, None

    if len(seq) < 10:
        return "⚠️ Too short (min 10)", None, "", "", None, None, None, None, None, None

    # Parse true Q3
    true_q3 = None
    if true_q3_str:
        true_clean = true_q3_str.upper().strip()
        if all(c in 'CHE' for c in true_clean):
            mapping = {'C': 0, 'H': 1, 'E': 2}
            true_q3 = [mapping[c] for c in true_clean]
        elif all(c in '012' for c in true_clean):
            true_q3 = [int(c) for c in true_clean]

        if true_q3 and len(true_q3) != len(seq):
            return f"⚠️ Length mismatch", None, "", "", None, None, None, None, None, None

    # Predict with ensemble if enabled
    if ensemble_mode and model_loaded:
        # Get GOR prediction
        gor_pred, gor_conf = gor_predict(seq)

        # Get model prediction
        features, _ = sequence_to_features(seq)
        if len(features) < 700:
            pad = np.zeros((700 - len(features), 63), dtype=np.float32)
            features = np.vstack([features, pad])

        with torch.no_grad():
            x = torch.from_numpy(features).unsqueeze(0).to(device)
            logits = model(x)
            probs = torch.softmax(logits, dim=-1).cpu().numpy()[0, :len(seq)]
            model_pred = logits.argmax(dim=-1).cpu().numpy()[0, :len(seq)]

        # Ensemble: average probabilities
        ensemble_conf = (probs + gor_conf) / 2
        pred_q3 = ensemble_conf.argmax(axis=1)
        confidences = ensemble_conf
        method = "Ensemble (GRU + GOR)"

    elif model_loaded:
        features, _ = sequence_to_features(seq)
        if len(features) < 700:
            pad = np.zeros((700 - len(features), 63), dtype=np.float32)
            features = np.vstack([features, pad])

        with torch.no_grad():
            x = torch.from_numpy(features).unsqueeze(0).to(device)
            logits = model(x)
            probs = torch.softmax(logits, dim=-1).cpu().numpy()[0, :len(seq)]
            pred_q3 = logits.argmax(dim=-1).cpu().numpy()[0, :len(seq)]

        confidences = probs
        method = "GRU Model"

    else:
        pred_q3, confidences = gor_predict(seq)
        method = "GOR Algorithm"

    # Convert to strings
    pred_str_che = ''.join([Q3_LABELS[p] for p in pred_q3])
    pred_str_012 = ''.join([str(p) for p in pred_q3])

    # Statistics
    c = sum(1 for p in pred_q3 if p == 0)
    h = sum(1 for p in pred_q3 if p == 1)
    e = sum(1 for p in pred_q3 if p == 2)
    total = len(pred_q3)

    # Create visualizations
    if true_q3 is None:
        true_q3 = pred_q3

    main_plot = plot_q3_comparison(np.array(true_q3), pred_q3, seq)
    conf_heatmap = create_confidence_heatmap(seq, confidences)
    struct_3d = create_3d_structure_plot(seq, pred_q3, confidences)
    stats_plot = create_structure_statistics_plot(pred_q3)
    segment_plot = create_segment_length_analysis(pred_q3)

    confusion_matrix = None
    if true_q3_str:
        confusion_matrix = create_transition_matrix(true_q3, pred_q3)

    # Result text
    accuracy_text = ""
    if true_q3_str:
        correct = sum(1 for i in range(len(pred_q3)) if pred_q3[i] == true_q3[i])
        accuracy = (correct / len(pred_q3)) * 100
        accuracy_text = f"\n**Q3 Accuracy:** {accuracy:.2f}% ({correct}/{len(pred_q3)} correct)"

    result = f"""
## 🎯 Advanced Prediction Results

**Method:** {method}
**Sequence Length:** {total} residues{accuracy_text}

### Composition:
- 🔵 **Coil:** {c} ({c/total*100:.1f}%)
- 🔴 **Helix:** {h} ({h/total*100:.1f}%)
- 🟡 **Strand:** {e} ({e/total*100:.1f}%)

### Sequence:
```
{seq}
```

**Model Status:** {'✅ Loaded' if model_loaded else '⚠️ Not loaded'}
"""

    return result, main_plot, pred_str_che, pred_str_012, conf_heatmap, struct_3d, stats_plot, segment_plot, confusion_matrix

# ==================== GRADIO INTERFACE ====================

custom_css = """
.gradio-container {max-width: 1600px !important}
.plot-container {border: 2px solid #e0e0e0; border-radius: 8px; padding: 10px;}
"""

examples = [
    ["", "", False],
    ["PEAQRAALERRKQALEQERERLQKELEELKAENERKLQAEIEELRAQAAEERRQRQAAEERRRKQ", "", True],
    ["GAMGSMNVQAEEQLQEVASQYRKLLKKELQALLQGQGMSEYDRDGLDAASYYAPVR", "", False],
]

with gr.Blocks(theme=gr.themes.Soft(), css=custom_css, title="Ultimate Protein Predictor") as demo:

    gr.Markdown("""
    # 🚀 Ultimate Protein Secondary Structure Prediction Platform
    ### Multi-Model Ensemble • 3D Visualization • Confidence Analysis • Batch Processing
    """)

    with gr.Tabs() as tabs:

        # ===== TAB 1: SINGLE SEQUENCE PREDICTION =====
        with gr.Tab("🔬 Single Sequence Analysis", id=0):
            with gr.Row():
                with gr.Column(scale=1):
                    gr.Markdown("### 📝 Input Configuration")

                    seq_input = gr.Textbox(
                        label="Amino Acid Sequence",
                        placeholder="MKTAYIAKQRQIS...",
                        lines=6
                    )

                    true_q3_input = gr.Textbox(
                        label="True Q3 (Optional)",
                        placeholder="CHHHEEECC... or 011122200...",
                        lines=2
                    )

                    ensemble_mode = gr.Checkbox(
                        label="🎯 Enable Ensemble Mode (GRU + GOR)",
                        value=False,
                        info="Combine predictions for higher accuracy"
                    )

                    predict_btn = gr.Button("🔍 Analyze Structure", variant="primary", size="lg")

                    gr.Markdown("""
                    ### 🎨 Features:
                    - **Ensemble Mode**: Combine GRU + GOR
                    - **Confidence Heatmap**: Per-residue probabilities
                    - **3D Visualization**: Interactive structure view
                    - **Statistical Analysis**: Segment lengths, distribution
                    - **Confusion Matrix**: Detailed accuracy breakdown
                    """)

                with gr.Column(scale=2):
                    result_md = gr.Markdown("### Results will appear here...")

                    main_viz = gr.Image(label="Q3 Structure Comparison", type="pil")

                    with gr.Row():
                        pred_che = gr.Textbox(label="CHE Format", lines=2)
                        pred_012 = gr.Textbox(label="012 Format", lines=2)

            with gr.Row():
                conf_heatmap = gr.Plot(label="Confidence Heatmap")
                stats_plot = gr.Plot(label="Structure Distribution")

            with gr.Row():
                struct_3d = gr.Plot(label="3D Structure Visualization")
                segment_plot = gr.Plot(label="Segment Length Analysis")

            with gr.Row():
                confusion_mtx = gr.Plot(label="Confusion Matrix (if true structure provided)")

            gr.Examples(
                examples=examples,
                inputs=[seq_input, true_q3_input, ensemble_mode]
            )

            predict_btn.click(
                fn=predict_advanced,
                inputs=[seq_input, true_q3_input, ensemble_mode],
                outputs=[result_md, main_viz, pred_che, pred_012, conf_heatmap,
                        struct_3d, stats_plot, segment_plot, confusion_mtx]
            )

        # ===== TAB 2: BATCH PROCESSING =====
        with gr.Tab("📦 Batch Processing", id=1):
            gr.Markdown("""
            ### Upload FASTA File for Batch Analysis
            Process multiple protein sequences simultaneously
            """)

            with gr.Row():
                with gr.Column():
                    fasta_file = gr.File(
                        label="Upload FASTA File",
                        file_types=[".fasta", ".fa", ".txt"]
                    )

                    batch_btn = gr.Button("🚀 Process Batch", variant="primary", size="lg")

                    batch_summary = gr.Textbox(label="Summary", lines=2)

                with gr.Column():
                    batch_results = gr.Dataframe(
                        label="Batch Results",
                        max_height=400
                    )

            with gr.Row():
                batch_plot = gr.Plot(label="Batch Analysis Visualization")

            batch_btn.click(
                fn=batch_process_sequences,
                inputs=[fasta_file],
                outputs=[batch_summary, batch_results, batch_plot]
            )

        # ===== TAB 3: DOCUMENTATION =====
        with gr.Tab("📚 Documentation", id=2):
            gr.Markdown("""
            # 📖 Complete Documentation

            ## 🎯 Features Overview

            ### 1. **Ensemble Prediction**
            Combines multiple algorithms for superior accuracy:
            - **GRU Model**: Deep learning with 63 features
            - **GOR Algorithm**: Information theory-based classic method
            - **Ensemble Mode**: Average probabilities from both methods

            **Expected Accuracy:**
            - GRU alone: ~70-75%
            - GOR alone: ~60-65%
            - Ensemble: ~75-80%

            ### 2. **Confidence Heatmap**
            Interactive visualization showing per-residue confidence for each structure type:
            - **High confidence** (>0.7): Reliable prediction
            - **Medium confidence** (0.5-0.7): Moderate certainty
            - **Low confidence** (<0.5): Ambiguous region

            ### 3. **3D Structure Visualization**
            Interactive 3D plot with:
            - Color-coded by confidence
            - Hover for residue details
            - Rotatable view
            - Sequence position on Z-axis

            ### 4. **Statistical Analysis**
            - **Distribution Plot**: Percentage of each structure type
            - **Segment Analysis**: Length distribution of continuous structures
            - **Confusion Matrix**: Detailed error analysis (when true structure provided)

            ### 5. **Batch Processing**
            Process multiple sequences from FASTA files:
            - Up to 50 sequences per batch
            - Automatic filtering (10-700 residues)
            - Summary statistics table
            - Comparative visualization

            ## 🎨 Q3 Format

            | Code | Structure | Color | Typical % |
            |------|-----------|-------|-----------|
            | 0 or C | Coil/Loop | Light Blue | 40-55% |
            | 1 or H | Helix | Red | 25-35% |
            | 2 or E | Strand | Yellow | 15-25% |

            ## 🔬 Algorithms Explained

            ### GOR Algorithm (Garnier-Osguthorpe-Robson)
            - Published 1978, proven method
            - Uses information values from known structures
            - Sliding window of 17 residues
            - Position-dependent scoring
            - Special rules for Proline, Glycine

            ### GRU Model
            - Bidirectional recurrent neural network
            - 128 hidden units, 2 layers
            - 63-dimensional input features:
              - One-hot encoding (20)
              - Position encoding (2)
              - Window composition (20)
              - GOR values (3)
              - Physicochemical properties (18)

            ## 📊 Understanding Results

            ### Confidence Interpretation
            - **Uniform confidence**: Sequence region is unambiguous
            - **Mixed confidence**: Transition regions or ambiguous structures
            - **Low confidence areas**: May benefit from experimental validation

            ### Segment Lengths
            - **Helices**: Typically 8-15 residues
            - **Strands**: Typically 5-10 residues
            - **Coils**: Variable, 3-20+ residues
            - Segments < 4 residues are filtered out

            ### Common Patterns
            - **All Proline**: Expect 100% coil
            - **Alternating hydrophobic**: May indicate β-sheets
            - **Long hydrophobic runs**: Often α-helices
            - **N/C terminals**: Usually coils

            ## 🚀 Best Practices

            1. **Use ensemble mode** for critical predictions
            2. **Check confidence heatmap** for ambiguous regions
            3. **Validate low-confidence regions** experimentally
            4. **Compare segment lengths** with known homologs
            5. **Use batch processing** for proteome-wide analysis

            ## 🔧 Technical Details

            **Minimum Structure Length:** 4 residues
            - Prevents unrealistic short helices/strands
            - Biologically meaningful segments

            **Position Effects:**
            - Terminal 20% favors coils
            - Central regions more likely structured

            **Special Residues:**
            - **P (Proline)**: Strong helix breaker, β-sheet breaker
            - **G (Glycine)**: Flexible, destabilizes regular structures
            - **V, I, T**: β-branched, favor sheets
            - **A, L, E, M**: Small/hydrophobic, favor helices

            ## 📈 Performance Metrics

            **Q3 Accuracy**: Percentage of correctly predicted residues

            **SOV (Segment Overlap)**: Measures segment-level accuracy

            **Per-Class Metrics**:
            - Precision: Correct predictions / All predictions for class
            - Recall: Correct predictions / All actual occurrences
            - F1-Score: Harmonic mean of precision and recall

            ## 🎓 Citation

            If you use this tool, please cite:
            - GOR: Garnier et al. (1978) J Mol Biol
            - Deep learning approaches in structural bioinformatics

            ---

            Built with PyTorch, Gradio, Plotly | Professional Bioinformatics Platform
            """)

    gr.Markdown(f"""
