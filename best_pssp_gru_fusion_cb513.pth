# Protein Secondary Structure Prediction (GRU) — CB513

This notebook runs a memory-efficient GRU model on the uploaded `CB513.npy` dataset (expected at `/mnt/data/CB513.npy`).

Features:
- memory-mapped dataset loading (no full-file in RAM)
- physiological/physicochemical feature fusion (6 extra features)
- bidirectional GRU model
- training loop, validation, loss/accuracy plots
- confusion matrix and per-class metrics

**Run the cells in order.**
"""

# Install minimal dependencies (uncomment if needed)
# !pip install --quiet torch torchvision scikit-learn matplotlib nbformat

import os, sys
import numpy as np
import torch
import torch.nn as nn
from torch.utils.data import Dataset, DataLoader, Subset
from sklearn.model_selection import train_test_split
from sklearn.metrics import confusion_matrix, classification_report
import matplotlib.pyplot as plt
import random
print('Libraries imported')

# Device and reproducibility
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print('Device:', device)

SEED = 42
random.seed(SEED)
np.random.seed(SEED)
torch.manual_seed(SEED)
if device.type == 'cuda':
    torch.cuda.manual_seed_all(SEED)

# Path to CB513.npy (uploaded by user). Change path if needed.
NPY_PATH = "/content/CB513.npy"
assert os.path.exists(NPY_PATH), f"File not found: {NPY_PATH}"

# Load memmap (read-only)
data = np.load(NPY_PATH, allow_pickle=True, mmap_mode='r')
print('raw shape:', data.shape)
N, FLAT = data.shape
L = 700
D = FLAT // L
assert L * D == FLAT, 'Shape mismatch; check L and original file'
data = data.reshape(N, L, D)
print('reshaped to', data.shape)
print('example first residue features (first 15 values):', data[0,0,:15])

# Amino acid order and physicochemical properties
AA_LIST = [
    'A','R','N','D','C','Q','E','G','H','I',
    'L','K','M','F','P','S','T','W','Y','V'
]
#hydrophobicity , charge , polarity , solvent accessibility , side chain pka , molecular weight
AA_PROPERTIES = {
 'A':[1.8,89.09,6.00,0,8.1,67],
 'R':[-4.5,174.20,10.76,1,10.5,148],
 'N':[-3.5,132.12,5.41,0,11.6,96],
 'D':[-3.5,133.10,2.77,-1,13.0,91],
 'C':[2.5,121.15,5.07,0,5.5,86],
 'Q':[-3.5,146.15,5.65,0,10.5,114],
 'E':[-3.5,147.13,3.22,-1,12.3,109],
 'G':[-0.4,75.07,5.97,0,9.0,48],
 'H':[-3.2,155.16,7.59,0,10.4,118],
 'I':[4.5,131.17,6.02,0,5.2,124],
 'L':[3.8,131.17,5.98,0,4.9,124],
 'K':[-3.9,146.19,9.74,1,11.3,135],
 'M':[1.9,149.21,5.74,0,5.7,124],
 'F':[2.8,165.19,5.48,0,5.2,135],
 'P':[-1.6,115.13,6.30,0,8.0,90],
 'S':[-0.8,105.09,5.68,0,9.2,73],
 'T':[-0.7,119.12,5.60,0,8.6,93],
 'W':[-0.9,204.23,5.89,0,5.4,163],
 'Y':[-1.3,181.19,5.66,0,6.2,141],
 'V':[4.2,117.15,5.96,0,5.9,105]
}
AA_PROP_DIM = 6
print('AA_PROPERTIES loaded with', AA_PROP_DIM, 'features per residue')

# indices based on earlier inspection
AA_ONE_HOT_DIM = 20
SST_ONE_HOT_START = 22
SST_ONE_HOT_END = 25  # exclusive

def extract_xy_mask_with_physchem(sample_row):
    # sample_row: (L, D)
    X = sample_row.astype(np.float32)
    sst_onehot = X[:, SST_ONE_HOT_START:SST_ONE_HOT_END]  # (L,3)
    y = np.argmax(sst_onehot, axis=-1).astype(np.int64)
    aa_onehot = X[:, :AA_ONE_HOT_DIM]
    mask = (aa_onehot.sum(axis=-1) > 0)
    # build physchem for each position
    physchem = np.zeros((X.shape[0], AA_PROP_DIM), dtype=np.float32)
    for i in range(X.shape[0]):
        if mask[i]:
            aa_index = int(np.argmax(aa_onehot[i]))
            aa_char = AA_LIST[aa_index]
            physchem[i] = np.array(AA_PROPERTIES[aa_char], dtype=np.float32)
        else:
            physchem[i] = np.zeros(AA_PROP_DIM, dtype=np.float32)
    # concat
    X_fused = np.concatenate([X, physchem], axis=-1)  # (L, D+AA_PROP_DIM)
    return X_fused, y, mask

# quick test
X0_f, y0_f, m0_f = extract_xy_mask_with_physchem(data[0])
print('fused shape per protein:', X0_f.shape, 'labels shape:', y0_f.shape, 'valid positions:', m0_f.sum())

class CB513MemmapDataset(Dataset):
    def __init__(self, memmap_array):
        self.data = memmap_array
        self.N = memmap_array.shape[0]
    def __len__(self): return self.N
    def __getitem__(self, idx):
        sample = self.data[idx]  # view (L,D)
        X, y, mask = extract_xy_mask_with_physchem(sample)
        return torch.from_numpy(X), torch.from_numpy(y).long(), torch.from_numpy(mask)

# create dataset and split

dataset = CB513MemmapDataset(data)
indices = list(range(len(dataset)))
train_idx, val_idx = train_test_split(indices, test_size=0.2, random_state=SEED)
train_ds = torch.utils.data.Subset(dataset, train_idx)
val_ds   = torch.utils.data.Subset(dataset, val_idx)
batch_size = 16
train_loader = DataLoader(train_ds, batch_size=batch_size, shuffle=True, num_workers=0, pin_memory=True)
val_loader   = DataLoader(val_ds,   batch_size=batch_size, shuffle=False, num_workers=0, pin_memory=True)
print('Train / Val sizes:', len(train_ds), len(val_ds))

# model definition
INPUT_DIM = D + AA_PROP_DIM  # 57 + 6 = 63
class GRU_SS_Model(nn.Module):
    def __init__(self, input_dim=INPUT_DIM, hidden_dim=128, num_layers=2, num_classes=3, dropout=0.2):
        super().__init__()
        self.gru = nn.GRU(input_size=input_dim, hidden_size=hidden_dim, num_layers=num_layers,
                          batch_first=True, bidirectional=True, dropout=dropout if num_layers>1 else 0.0)
        self.classifier = nn.Linear(hidden_dim*2, num_classes)
    def forward(self, x):
        out, _ = self.gru(x)
        logits = self.classifier(out)
        return logits

model = GRU_SS_Model().to(device)
print(model)
print('Total trainable params:', sum(p.numel() for p in model.parameters() if p.requires_grad))

criterion = nn.CrossEntropyLoss(ignore_index=-100)
optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)
scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=2)

def train_one_epoch(model, loader, optimizer, criterion, device):
    model.train()
    total_loss = 0.0
    for Xb, yb, maskb in loader:
        Xb = Xb.to(device)
        yb = yb.to(device)
        maskb = maskb.to(device)
        # mask padded labels
        yb_masked = yb.clone()
        yb_masked[~maskb] = -100
        optimizer.zero_grad()
        logits = model(Xb)
        loss = criterion(logits.view(-1, 3), yb_masked.view(-1))
        loss.backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=5.0)
        optimizer.step()
        total_loss += loss.item()
    return total_loss / max(1, len(loader))

def validate(model, loader, criterion, device):
    model.eval()
    total_loss = 0.0
    correct = 0
    total = 0
    with torch.no_grad():
        for Xb, yb, maskb in loader:
            Xb = Xb.to(device)
            yb = yb.to(device)
            maskb = maskb.to(device)
            yb_masked = yb.clone()
            yb_masked[~maskb] = -100
            logits = model(Xb)
            loss = criterion(logits.view(-1, 3), yb_masked.view(-1))
            total_loss += loss.item()
            preds = logits.argmax(dim=-1)
            correct += ((preds == yb) & maskb).sum().item()
            total += maskb.sum().item()
    acc = correct / total if total>0 else 0.0
    return total_loss / max(1, len(loader)), acc

# training driver
epochs = 25
best_val_loss = float('inf')
train_losses = []
val_losses = []
val_accs = []

for epoch in range(1, epochs+1):
    tr_loss = train_one_epoch(model, train_loader, optimizer, criterion, device)
    val_loss, val_acc = validate(model, val_loader, criterion, device)
    scheduler.step(val_loss)
    train_losses.append(tr_loss)
    val_losses.append(val_loss)
    val_accs.append(val_acc)
    print(f'Epoch {epoch}/{epochs} | Train Loss {tr_loss:.4f} | Val Loss {val_loss:.4f} | Val Q3 {val_acc:.4f}')
    if val_loss < best_val_loss:
        best_val_loss = val_loss
        torch.save(model.state_dict(), 'best_gru_fusion_cb513.pth')
        print('Saved best_gru_fusion_cb513.pth')

# Plot training/validation loss and validation Q3 accuracy
plt.figure()
plt.plot(train_losses)
plt.title('Train Loss per Epoch')
plt.xlabel('Epoch')
plt.ylabel('Loss')
plt.show()

plt.figure()
plt.plot(val_losses)
plt.title('Validation Loss per Epoch')
plt.xlabel('Epoch')
plt.ylabel('Loss')
plt.show()

plt.figure()
plt.plot(val_accs)
plt.title('Validation Q3 Accuracy per Epoch')
plt.xlabel('Epoch')
plt.ylabel('Q3 Accuracy')
plt.show()

# Evaluation and confusion matrix
model.load_state_dict(torch.load('best_gru_fusion_cb513.pth', map_location=device))
model.to(device)
model.eval()

all_preds = []
all_trues = []

with torch.no_grad():
    for Xb, yb, maskb in val_loader:
        Xb = Xb.to(device)
        yb = yb.to(device)
        maskb = maskb.to(device)
        logits = model(Xb)
        preds = logits.argmax(dim=-1).cpu().numpy()
        y_np = yb.cpu().numpy()
        mask_np = maskb.cpu().numpy()
        for i in range(preds.shape[0]):
            valid_idx = mask_np[i].astype(bool)
            all_preds.extend(preds[i, valid_idx].tolist())
            all_trues.extend(y_np[i, valid_idx].tolist())

from sklearn.metrics import confusion_matrix, classification_report
cm = confusion_matrix(all_trues, all_preds, labels=[0,1,2])
print('Confusion matrix (rows=true, cols=pred):\n', cm)
print('\nClassification report:\n', classification_report(all_trues, all_preds, target_names=['H','E','C']))

plt.figure()
plt.imshow(cm, interpolation='nearest')
plt.title('Confusion Matrix')
plt.xlabel('Predicted label')
plt.ylabel('True label')
plt.colorbar()
plt.xticks([0,1,2], ['H','E','C'])
plt.yticks([0,1,2], ['H','E','C'])
plt.show()

# ===============================================================
# ⚒ VISUALIZE TRUE vs PREDICTED PROTEIN SECONDARY STRUCTURE
# Ribbon-style plot for Q3 (Helix, Sheet, Coil)
# ===============================================================

import numpy as np
import matplotlib.pyplot as plt
import torch

# ---------------------------
# Helper: Convert Q3 indices (0,1,2) → Q3 characters (H,E,C)
# Based on target_names=['H','E','C'] where 0=H, 1=E, 2=C
# ---------------------------
def map_q3_indices_to_chars(q3_seq_indices):
    q3_chars = []
    for idx in q3_seq_indices:
        if idx == 0:      # 0 corresponds to Helix (H)
            q3_chars.append("H")
        elif idx == 1:    # 1 corresponds to Extended strand (E)
            q3_chars.append("E")
        elif idx == 2:    # 2 corresponds to Coil (C)
            q3_chars.append("C")
        else:
            # Should not happen with a 3-class model output
            q3_chars.append("?")
    return q3_chars

# ----------------------------------
# Choose a test protein to visualize
# ----------------------------------
protein_batch_idx = 0   # Index of the protein within the first batch from the loader
model.eval()

# Get a single batch from the validation data loader
# val_loader is defined in a previous cell (5f074a28)
inputs_batch, targets_batch, masks_batch = next(iter(val_loader))

# Move batch to device
inputs_batch = inputs_batch.to(device)
targets_batch = targets_batch.to(device)
masks_batch = masks_batch.to(device)

# Predict
with torch.no_grad():
    logits_batch = model(inputs_batch) # Shape: (batch_size, L, num_classes=3)
    pred_indices_batch = torch.argmax(logits_batch, dim=-1) # Shape: (batch_size, L)

# Extract data for the chosen protein from the batch
# Get valid length for the selected protein (remove padding)
valid_len = masks_batch[protein_batch_idx].sum().item()

# Get true and predicted secondary structure indices for the valid part of the protein
true_seq_indices = targets_batch[protein_batch_idx, :valid_len].cpu().numpy()
pred_seq_indices = pred_indices_batch[protein_batch_idx, :valid_len].cpu().numpy()

# Convert indices to character representations
pred_q3_chars = map_q3_indices_to_chars(pred_seq_indices)
true_q3_chars = map_q3_indices_to_chars(true_seq_indices)

L0 = valid_len  # Actual length of the protein sequence

# ----------------------------------
# Plot as a ribbon
# ----------------------------------

color_map = {"H": "red", "E": "gold", "C": "lightblue"}

plt.figure(figsize=(18,3))

# Plot TRUE structure
plt.subplot(2,1,1)
plt.title(f"True Secondary Structure (Q3) for Protein (Length: {L0})")
for i, s in enumerate(true_q3_chars):
    plt.bar(i, 1, color=color_map[s])
plt.yticks([])
plt.xlabel("Residue Index")
plt.xlim(-0.5, L0 - 0.5) # Adjust x-axis limits for better visualization

# Plot PREDICTED structure
plt.subplot(2,1,2)
plt.title(f"Predicted Secondary Structure (Q3) for Protein (Length: {L0})")
for i, s in enumerate(pred_q3_chars):
    plt.bar(i, 1, color=color_map[s])
plt.yticks([])
plt.xlabel("Residue Index")
plt.xlim(-0.5, L0 - 0.5) # Adjust x-axis limits for better visualization

plt.tight_layout()
plt.show()

print("Legend:")
print("H = Helix (red)")
print("E = Sheet (gold)")
print("C = Coil (lightblue)")

# ===============================================================
# PROFESSIONAL 3D PROTEIN SECONDARY STRUCTURE VISUALIZATION
# Enhanced version with improved visual quality and error handling
# ===============================================================
import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D
from matplotlib.patches import FancyArrowPatch
from mpl_toolkits.mplot3d.proj3d import proj_transform
import torch
from scipy.interpolate import CubicSpline
from matplotlib import cm
import warnings
warnings.filterwarnings('ignore')

# -----------------------
# Configuration Parameters
# -----------------------
SAMPLE_IDX = 5              # Test protein sample index
BACKBONE_SCALE = 1.2        # Backbone spacing scale
HELIX_RADIUS = 0.8          # Alpha helix radius
HELIX_PITCH = 5.4           # Angstroms per turn (biological accuracy)
SHEET_WIDTH = 1.2           # Beta sheet width
SHEET_THICKNESS = 0.15      # Sheet thickness for 3D effect
COIL_THICKNESS = 0.4        # Coil loop thickness
RESOLUTION_FACTOR = 12      # Smoothness of curves (higher = smoother)

# Professional color scheme (using scientifically standard colors)
COLOR_SCHEME = {
    0: {'main': '#E41A1C', 'dark': '#B30000', 'light': '#FF6B6B', 'name': 'α-Helix'},    # Red
    1: {'main': '#FFD700', 'dark': '#DAA520', 'light': '#FFED4E', 'name': 'β-Sheet'},    # Gold
    2: {'main': '#4DAF4A', 'dark': '#2E7D2C', 'light': '#81C784', 'name': 'Coil/Loop'}   # Green
}

# -----------------------
# Data Retrieval Function
# -----------------------
def get_prediction_and_truth(idx, model, val_ds, device):
    """
    Retrieve predicted and true secondary structures for a given sample.

    Args:
        idx: Sample index
        model: Trained PyTorch model
        val_ds: Validation dataset
        device: Torch device

    Returns:
        pred: Predicted labels array
        true: True labels array
        valid_len: Valid sequence length
    """
    try:
        model.eval()
        with torch.no_grad():
            X_sample, y_sample, mask_sample = val_ds[idx]

            # Prepare input
            inp = X_sample.unsqueeze(0).float().to(device)

            # Get predictions
            logits = model(inp)
            pred = logits.argmax(dim=-1).cpu().numpy()[0]

        true = y_sample.cpu().numpy()
        valid_len = int(mask_sample.sum().item())

        return pred[:valid_len], true[:valid_len], valid_len

    except Exception as e:
        print(f"Error retrieving data: {e}")
        raise

# -----------------------
# Backbone Generation
# -----------------------
def generate_backbone_curve(n, scale=BACKBONE_SCALE):
    """
    Generate smooth 3D backbone coordinates using cubic spline interpolation.
    Creates a biologically-inspired curved backbone.
    """
    t = np.linspace(0, 1, n)

    # Create a smooth 3D curve with biological realism
    x = scale * (3.0 * np.sin(2 * np.pi * t * 0.4) + 0.5 * np.sin(2 * np.pi * t * 1.5))
    y = scale * (3.0 * np.cos(2 * np.pi * t * 0.3) + 0.5 * np.cos(2 * np.pi * t * 1.2))
    z = scale * (t * 15.0 + 0.3 * np.sin(2 * np.pi * t * 2.0))

    # Apply cubic spline for smooth interpolation
    cs_x = CubicSpline(t, x, bc_type='natural')
    cs_y = CubicSpline(t, y, bc_type='natural')
    cs_z = CubicSpline(t, z, bc_type='natural')

    # High-resolution sampling
    t_fine = np.linspace(0, 1, n * RESOLUTION_FACTOR)

    return cs_x(t_fine), cs_y(t_fine), cs_z(t_fine), t_fine

# -----------------------
# Local Frame Calculation
# -----------------------
def compute_frenet_frame(x, y, z):
    """
    Compute Frenet-Serret frame (tangent, normal, binormal) for 3D curve.
    This provides proper orientation for secondary structure elements.
    """
    # Tangent vector (first derivative)
    tx = np.gradient(x)
    ty = np.gradient(y)
    tz = np.gradient(z)
    t_norm = np.sqrt(tx**2 + ty**2 + tz**2) + 1e-10
    tx /= t_norm
    ty /= t_norm
    tz /= t_norm

    # Normal vector (second derivative)
    dtx = np.gradient(tx)
    dty = np.gradient(ty)
    dtz = np.gradient(tz)
    n_norm = np.sqrt(dtx**2 + dty**2 + dtz**2) + 1e-10
    nx = dtx / n_norm
    ny = dty / n_norm
    nz = dtz / n_norm

    # Binormal vector (cross product)
    bx = ty * nz - tz * ny
    by = tz * nx - tx * nz
    bz = tx * ny - ty * nx
    b_norm = np.sqrt(bx**2 + by**2 + bz**2) + 1e-10
    bx /= b_norm
    by /= b_norm
    bz /= b_norm

    return (tx, ty, tz), (nx, ny, nz), (bx, by, bz)

# -----------------------
# Alpha Helix Rendering
# -----------------------
def render_helix(ax, start_idx, end_idx, bx, by, bz, t_indices, res_positions):
    """
    Render alpha helix with proper helical geometry and ribbons.
    """
    seg_len = end_idx - start_idx + 1

    if seg_len < 3:
        # Too short for helix, render as coil
        idx_range = res_positions[start_idx:end_idx+1]
        ax.plot(bx[idx_range], by[idx_range], bz[idx_range],
                color=COLOR_SCHEME[0]['main'], linewidth=3, alpha=0.9)
        return

    # Get segment parameters
    t_start = t_indices[res_positions[start_idx]]
    t_end = t_indices[res_positions[end_idx]]
    t_seg = np.linspace(t_start, t_end, seg_len * 10)

    # Interpolate backbone
    seg_x = np.interp(t_seg, t_indices, bx)
    seg_y = np.interp(t_seg, t_indices, by)
    seg_z = np.interp(t_seg, t_indices, bz)

    # Compute local frame
    tangent, normal, binormal = compute_frenet_frame(seg_x, seg_y, seg_z)
    tx, ty, tz = tangent
    nx, ny, nz = normal

    # Helix parameters
    radius = HELIX_RADIUS
    turns = seg_len / 3.6  # 3.6 residues per turn (biological)
    theta = np.linspace(0, 2 * np.pi * turns, len(t_seg))

    # Generate helix coordinates
    hx = seg_x + radius * (nx * np.cos(theta) + binormal[0] * np.sin(theta))
    hy = seg_y + radius * (ny * np.cos(theta) + binormal[1] * np.sin(theta))
    hz = seg_z + radius * (nz * np.cos(theta) + binormal[2] * np.sin(theta))

    # Draw main helix with gradient effect
    points = np.array([hx, hy, hz]).T.reshape(-1, 1, 3)
    segments = np.concatenate([points[:-1], points[1:]], axis=1)

    # Plot with varying alpha for depth effect
    for i in range(0, len(hx)-1, 2):
        alpha_val = 0.7 + 0.3 * np.sin(theta[i])
        ax.plot(hx[i:i+2], hy[i:i+2], hz[i:i+2],
                color=COLOR_SCHEME[0]['main'], linewidth=4, alpha=alpha_val, solid_capstyle='round')

    # Add central axis for clarity
    ax.plot(seg_x, seg_y, seg_z, color=COLOR_SCHEME[0]['dark'],
            linewidth=1.5, alpha=0.4, linestyle='--')

# -----------------------
# Beta Sheet Rendering
# -----------------------
def render_sheet(ax, start_idx, end_idx, bx, by, bz, t_indices, res_positions):
    """
    Render beta sheet as flat ribbon with arrow indicating directionality.
    """
    seg_len = end_idx - start_idx + 1

    if seg_len < 2:
        idx_range = res_positions[start_idx:end_idx+1]
        ax.plot(bx[idx_range], by[idx_range], bz[idx_range],
                color=COLOR_SCHEME[1]['main'], linewidth=4, alpha=0.9)
        return

    # Get segment
    t_start = t_indices[res_positions[start_idx]]
    t_end = t_indices[res_positions[end_idx]]
    t_seg = np.linspace(t_start, t_end, seg_len * 8)

    seg_x = np.interp(t_seg, t_indices, bx)
    seg_y = np.interp(t_seg, t_indices, by)
    seg_z = np.interp(t_seg, t_indices, bz)

    # Compute local frame
    tangent, normal, binormal = compute_frenet_frame(seg_x, seg_y, seg_z)
    nx, ny, nz = normal

    # Create ribbon edges
    width = SHEET_WIDTH
    edge1_x = seg_x + nx * width / 2
    edge1_y = seg_y + ny * width / 2
    edge1_z = seg_z + nz * width / 2

    edge2_x = seg_x - nx * width / 2
    edge2_y = seg_y - ny * width / 2
    edge2_z = seg_z - nz * width / 2

    # Draw ribbon surfaces with shading
    for i in range(len(seg_x) - 1):
        # Main surface
        xs = [edge1_x[i], edge1_x[i+1], edge2_x[i+1], edge2_x[i]]
        ys = [edge1_y[i], edge1_y[i+1], edge2_y[i+1], edge2_y[i]]
        zs = [edge1_z[i], edge1_z[i+1], edge2_z[i+1], edge2_z[i]]

        verts = [list(zip(xs, ys, zs))]
        ax.add_collection3d(plt.matplotlib.collections.Poly3DCollection(
            verts, facecolors=COLOR_SCHEME[1]['light'],
            edgecolors=COLOR_SCHEME[1]['dark'], alpha=0.8, linewidths=0.5))

    # Draw edges for definition
    ax.plot(edge1_x, edge1_y, edge1_z, color=COLOR_SCHEME[1]['dark'], linewidth=2.5, alpha=0.9)
    ax.plot(edge2_x, edge2_y, edge2_z, color=COLOR_SCHEME[1]['dark'], linewidth=2.5, alpha=0.9)

    # Add arrowhead at C-terminus
    arrow_scale = 0.8
    ax.plot([edge1_x[-5], edge1_x[-1] + nx[-1] * arrow_scale],
            [edge1_y[-5], edge1_y[-1] + ny[-1] * arrow_scale],
            [edge1_z[-5], edge1_z[-1] + nz[-1] * arrow_scale],
            color=COLOR_SCHEME[1]['dark'], linewidth=3, alpha=0.9)
    ax.plot([edge2_x[-5], edge2_x[-1] - nx[-1] * arrow_scale],
            [edge2_y[-5], edge2_y[-1] - ny[-1] * arrow_scale],
            [edge2_z[-5], edge2_z[-1] - nz[-1] * arrow_scale],
            color=COLOR_SCHEME[1]['dark'], linewidth=3, alpha=0.9)

# -----------------------
# Coil/Loop Rendering
# -----------------------
def render_coil(ax, start_idx, end_idx, bx, by, bz, t_indices, res_positions):
    """
    Render coil regions as smooth tube.
    """
    seg_len = end_idx - start_idx + 1
    idx_range = res_positions[start_idx:end_idx+1]

    # Higher resolution for smooth curves
    t_start = t_indices[res_positions[start_idx]]
    t_end = t_indices[res_positions[end_idx]]
    t_seg = np.linspace(t_start, t_end, max(seg_len * 6, 20))

    seg_x = np.interp(t_seg, t_indices, bx)
    seg_y = np.interp(t_seg, t_indices, by)
    seg_z = np.interp(t_seg, t_indices, bz)

    # Draw as thick line with caps
    ax.plot(seg_x, seg_y, seg_z, color=COLOR_SCHEME[2]['main'],
            linewidth=3.5, alpha=0.85, solid_capstyle='round')

# -----------------------
# Segment Identification
# -----------------------
def identify_segments(labels):
    """
    Identify continuous segments of same secondary structure.
    """
    if len(labels) == 0:
        return []

    segments = []
    current_label = int(labels[0])
    start = 0

    for i in range(1, len(labels)):
        if int(labels[i]) != current_label:
            segments.append((start, i - 1, current_label))
            start = i
            current_label = int(labels[i])

    segments.append((start, len(labels) - 1, current_label))
    return segments

# -----------------------
# Main Visualization Function
# -----------------------
def visualize_protein_structure(sample_idx, model, val_ds, device):
    """
    Create professional 3D visualization of predicted protein secondary structure.
    """
    print(f"Generating visualization for sample {sample_idx}...")

    # Get predictions
    pred_labels, true_labels, valid_len = get_prediction_and_truth(
        sample_idx, model, val_ds, device)

    print(f"Sequence length: {valid_len} residues")

    # Generate backbone
    bx, by, bz, t_indices = generate_backbone_curve(valid_len)
    res_positions = np.linspace(0, len(t_indices) - 1, valid_len).astype(int)

    res_x = bx[res_positions]
    res_y = by[res_positions]
    res_z = bz[res_positions]

    # Identify segments
    pred_segments = identify_segments(pred_labels)
    true_segments = identify_segments(true_labels)

    # Count structures
    pred_counts = {0: 0, 1: 0, 2: 0}
    for s, e, lbl in pred_segments:
        pred_counts[lbl] += (e - s + 1)

    # Create figure
    fig = plt.figure(figsize=(16, 10), facecolor='white')
    ax = fig.add_subplot(111, projection='3d', facecolor='#F8F8F8')

    # Plot faint backbone guide
    ax.plot(bx, by, bz, color='gray', linewidth=0.8, alpha=0.2, linestyle=':')

    # Render each segment
    print("Rendering structure elements...")
    for start, end, label in pred_segments:
        if label == 0:  # Helix
            render_helix(ax, start, end, bx, by, bz, t_indices, res_positions)
        elif label == 1:  # Sheet
            render_sheet(ax, start, end, bx, by, bz, t_indices, res_positions)
        else:  # Coil
            render_coil(ax, start, end, bx, by, bz, t_indices, res_positions)

    # Overlay residue markers
    colors = [COLOR_SCHEME[int(l)]['main'] for l in pred_labels]
    ax.scatter(res_x, res_y, res_z, c=colors, s=20, alpha=0.6,
               edgecolors='white', linewidths=0.5)

    # Add comparison with true structure (offset)
    offset = 4.0
    true_colors = [COLOR_SCHEME[int(l)]['main'] for l in true_labels]
    ax.scatter(res_x + offset, res_y, res_z, c=true_colors, s=25,
               alpha=0.7, marker='s', edgecolors='black', linewidths=0.5,
               label='True Structure')

    # Styling
    ax.set_xlabel('X Coordinate (Å)', fontsize=11, fontweight='bold')
    ax.set_ylabel('Y Coordinate (Å)', fontsize=11, fontweight='bold')
    ax.set_zlabel('Z Coordinate (Å)', fontsize=11, fontweight='bold')
    ax.set_title(f'3D Protein Secondary Structure Prediction (Sample {sample_idx})\n'
                 f'Predicted (left) vs True (right, offset)',
                 fontsize=14, fontweight='bold', pad=20)

    # Set optimal viewing angle
    ax.view_init(elev=20, azim=-65)

    # Set equal aspect ratio for proper visualization
    ax.set_box_aspect([1, 1, 1.2])

    # Grid styling
    ax.grid(True, alpha=0.3, linestyle='--', linewidth=0.5)
    ax.xaxis.pane.fill = False
    ax.yaxis.pane.fill = False
    ax.zaxis.pane.fill = False

    # Create custom legend
    from matplotlib.lines import Line2D
    legend_elements = [
        Line2D([0], [0], color=COLOR_SCHEME[0]['main'], linewidth=4,
               label=f"{COLOR_SCHEME[0]['name']} ({pred_counts[0]} res)"),
        Line2D([0], [0], color=COLOR_SCHEME[1]['main'], linewidth=4,
               label=f"{COLOR_SCHEME[1]['name']} ({pred_counts[1]} res)"),
        Line2D([0], [0], color=COLOR_SCHEME[2]['main'], linewidth=4,
               label=f"{COLOR_SCHEME[2]['name']} ({pred_counts[2]} res)")
    ]
    ax.legend(handles=legend_elements, loc='upper left', fontsize=10,
              framealpha=0.9, shadow=True)

    plt.tight_layout()
    plt.show()

    # Print statistics
    print("\n" + "="*60)
    print("STRUCTURE COMPOSITION")
    print("="*60)
    for lbl in [0, 1, 2]:
        pct = 100 * pred_counts[lbl] / valid_len
        print(f"{COLOR_SCHEME[lbl]['name']:12s}: {pred_counts[lbl]:3d} residues ({pct:5.1f}%)")
    print("="*60)

    print(f"\nSegments identified: {len(pred_segments)}")
    print("\nSegment details (start, end, type):")
    for i, (s, e, lbl) in enumerate(pred_segments[:10], 1):
        print(f"  {i:2d}. Residues {s:3d}-{e:3d}: {COLOR_SCHEME[lbl]['name']}")
    if len(pred_segments) > 10:
        print(f"  ... and {len(pred_segments) - 10} more segments")

    return fig, ax

# -----------------------
# Execute Visualization
# -----------------------
# Main execution
try:
    fig, ax = visualize_protein_structure(SAMPLE_IDX, model, val_ds, device)
    print("\n✓ Visualization complete!")
except Exception as e:
    print(f"✗ Error during visualization: {e}")
    import traceback
    traceback.print_exc()

# ===============================================================
# PROFESSIONAL RESIDUE-LEVEL IMPORTANCE ANALYSIS
# Method: Gradient × Input (Saliency Mapping)
# Enhanced visualization with publication-quality aesthetics
# ===============================================================

import numpy as np
import torch
import matplotlib.pyplot as plt
from matplotlib import cm
from matplotlib.patches import Rectangle, FancyBboxPatch
from matplotlib.gridspec import GridSpec
import seaborn as sns
from scipy.ndimage import gaussian_filter1d
import warnings
warnings.filterwarnings('ignore')

# Set professional plotting style
plt.style.use('seaborn-v0_8-darkgrid')
sns.set_palette("husl")

# =====================================
# CONFIGURATION PARAMETERS
# =====================================
SAMPLE_INDICES = [0, 1, 2, 3, 4]      # Dataset indices to analyze
MAX_SAMPLES = 16                       # Safety limit
NORMALIZE_PER_SEQ = True               # Normalize importance per sequence
COLORMAP_HEATMAP = "RdYlBu_r"         # Professional diverging colormap
COLORMAP_LINES = "viridis"             # Line plot colormap
SMOOTH_SIGMA = 0.8                     # Gaussian smoothing for line plots

# Feature dimensions (adjust to your model)
AA_ONE_HOT_DIM = 20
SST_ONE_HOT_START = 22
SST_ONE_HOT_END = 25

# Secondary structure color scheme
SS_COLORS = {
    0: {'color': '#E74C3C', 'name': 'α-Helix', 'light': '#FADBD8'},    # Red
    1: {'color': '#F39C12', 'name': 'β-Sheet', 'light': '#FEF5E7'},    # Orange
    2: {'color': '#3498DB', 'name': 'Coil/Loop', 'light': '#D6EAF8'}     # Blue
}

# =====================================
# UTILITY FUNCTIONS
# =====================================

def get_mask_from_sample_array(sample_arr):
    """
    Extract boolean mask for valid (non-padded) residues.

    Args:
        sample_arr: Input array (L, features)

    Returns:
        mask: Boolean array (L,) - True for valid residues
    """
    aa_onehot = sample_arr[:, :AA_ONE_HOT_DIM]
    return (aa_onehot.sum(axis=-1) > 0)


def compute_saliency_for_sample(idx, model, dataset, device):
    """
    Compute gradient × input importance scores per residue.

    Args:
        idx: Sample index in dataset
        model: Trained neural network model
        dataset: Dataset object with .data attribute
        device: PyTorch device

    Returns:
        importance: (L,) importance scores
        mask: (L,) validity mask
        y_true: (L,) true labels
        y_pred: (L,) predicted labels
    """
    # Extract raw sample
    raw_sample = dataset.data[idx]

    # Reconstruct fused features (assumes extract_xy_mask_with_physchem exists)
    X_fused, y_true, mask = extract_xy_mask_with_physchem(raw_sample)

    # Convert to tensors
    X = torch.tensor(X_fused, dtype=torch.float32, device=device,
                     requires_grad=True).unsqueeze(0)  # (1, L, D)
    y_tensor = torch.tensor(y_true, dtype=torch.long, device=device).unsqueeze(0)
    mask_t = torch.tensor(mask, device=device)

    # Mask invalid positions
    y_masked = y_tensor.clone()
    y_masked[0, ~mask_t] = -100

    # Save original model state
    was_training = model.training
    original_dropout = model.gru.dropout if hasattr(model, 'gru') else 0.0

    # Set to train mode for gradient computation (disable dropout)
    model.train()
    if hasattr(model, 'gru'):
        model.gru.dropout = 0.0

    try:
        # Forward pass
        logits = model(X)  # (1, L, C)

        # Compute loss
        loss_fn = torch.nn.CrossEntropyLoss(ignore_index=-100, reduction='mean')
        loss = loss_fn(logits.view(-1, logits.shape[-1]), y_masked.view(-1))

        # Compute gradients
        grad_tensor = torch.autograd.grad(
            outputs=loss,
            inputs=X,
            create_graph=False,
            retain_graph=False
        )[0]

        # Get predictions
        y_pred = logits.argmax(dim=-1).detach().cpu().numpy()[0]

    finally:
        # Restore model state
        if hasattr(model, 'gru'):
            model.gru.dropout = original_dropout
        if not was_training:
            model.eval()

    # Compute importance: |sum(input * gradient)|
    grad = grad_tensor.detach().cpu().numpy()[0]  # (L, D)
    inp = X.detach().cpu().numpy()[0]              # (L, D)
    importance = np.abs(np.sum(inp * grad, axis=-1))

    # Zero out padded positions
    importance[~mask] = 0.0

    return importance, mask, y_true, y_pred


def normalize_importance(importance_array, mask):
    """
    Normalize importance scores to [0, 1] range.
    """
    valid_importance = importance_array[mask]
    if valid_importance.max() > 0:
        normalized = np.zeros_like(importance_array)
        normalized[mask] = (valid_importance - valid_importance.min()) / \
                          (valid_importance.max() - valid_importance.min() + 1e-12)
        return normalized
    return importance_array


# =====================================
# MAIN ANALYSIS FUNCTION
# =====================================

def analyze_residue_importance(sample_indices, model, dataset, device):
    """
    Compute importance scores for multiple samples.
    """
    print("=" * 70)
    print("RESIDUE IMPORTANCE ANALYSIS - GRADIENT × INPUT SALIENCY")
    print("=" * 70)

    # Handle dataset wrapper
    if isinstance(dataset, torch.utils.data.Subset):
        base_dataset = dataset.dataset
    else:
        base_dataset = dataset

    # Storage
    results = []

    # Process each sample
    indices = sample_indices[:MAX_SAMPLES]
    print(f"\nProcessing {len(indices)} samples...")

    for i, idx in enumerate(indices):
        print(f"  [{i+1}/{len(indices)}] Sample {idx}...", end=" ")

        importance, mask, y_true, y_pred = compute_saliency_for_sample(
            idx, model, base_dataset, device
        )

        # Normalize if requested
        if NORMALIZE_PER_SEQ:
            importance = normalize_importance(importance, mask)

        valid_len = int(mask.sum())

        # Calculate accuracy for this sample
        accuracy = np.mean(y_pred[:valid_len] == y_true[:valid_len]) * 100

        results.append({
            'idx': idx,
            'importance': importance,
            'mask': mask,
            'y_true': y_true,
            'y_pred': y_pred,
            'valid_len': valid_len,
            'accuracy': accuracy
        })

        print(f"Length: {valid_len}, Accuracy: {accuracy:.1f}%")

    print("\n✓ Analysis complete!\n")
    return results


# =====================================
# VISUALIZATION 1: HEATMAP OVERVIEW
# =====================================

def plot_heatmap_overview(results, save_path=None):
    """
    Create professional heatmap showing importance across all samples.
    """
    max_len = max(r['valid_len'] for r in results)
    n_samples = len(results)

    # Prepare heatmap matrix
    heatmap = np.zeros((n_samples, max_len), dtype=np.float32)
    for i, res in enumerate(results):
        imp = res['importance'][:max_len]
        heatmap[i, :len(imp)] = imp

    # Create figure with custom layout
    fig = plt.figure(figsize=(18, max(6, n_samples * 0.6)))
    gs = GridSpec(1, 20, figure=fig, wspace=0.3)

    ax_main = fig.add_subplot(gs[0, :18])
    ax_cbar = fig.add_subplot(gs[0, 19])

    # Plot heatmap
    im = ax_main.imshow(
        heatmap,
        aspect='auto',
        cmap=COLORMAP_HEATMAP,
        interpolation='bilinear',
        origin='lower'
    )

    # Colorbar
    cbar = plt.colorbar(im, cax=ax_cbar)
    cbar.set_label(
        'Normalized Importance\n(Gradient × Input)',
        fontsize=11,
        fontweight='bold',
        rotation=270,
        labelpad=25
    )
    cbar.ax.tick_params(labelsize=9)

    # Styling
    ax_main.set_xlabel('Residue Position', fontsize=12, fontweight='bold')
    ax_main.set_ylabel('Sample Index', fontsize=12, fontweight='bold')
    ax_main.set_title(
        'Residue-Level Importance Heatmap\nSaliency Analysis Across Protein Sequences',
        fontsize=14,
        fontweight='bold',
        pad=20
    )

    # Y-axis labels with sample info
    y_labels = [
        f"#{r['idx']:03d} (L={r['valid_len']}, Acc={r['accuracy']:.0f}%)"
        for r in results
    ]
    ax_main.set_yticks(range(n_samples))
    ax_main.set_yticklabels(y_labels, fontsize=9)

    # X-axis styling
    ax_main.set_xticks(np.arange(0, max_len, max(1, max_len // 20)))
    ax_main.tick_params(axis='x', labelsize=9)

    # Add grid for readability
    ax_main.set_xticks(np.arange(-0.5, max_len, 50), minor=True)
    ax_main.set_yticks(np.arange(-0.5, n_samples, 1), minor=True)
    ax_main.grid(which='minor', color='white', linewidth=1.5, alpha=0.4)

    # Add statistics box
    total_residues = sum(r['valid_len'] for r in results)
    avg_accuracy = np.mean([r['accuracy'] for r in results])

    stats_text = (
        f"Samples: {n_samples}\n"
        f"Total Residues: {total_residues}\n"
        f"Avg Accuracy: {avg_accuracy:.1f}%"
    )

    ax_main.text(
        0.02, 0.98, stats_text,
        transform=ax_main.transAxes,
        fontsize=9,
        verticalalignment='top',
        bbox=dict(boxstyle='round,pad=0.5', facecolor='white',
                  edgecolor='gray', alpha=0.9)
    )

    plt.tight_layout()

    if save_path:
        plt.savefig(save_path, dpi=300, bbox_inches='tight', facecolor='white')
        print(f"✓ Heatmap saved to {save_path}")

    plt.show()


# =====================================
# VISUALIZATION 2: DETAILED LINE PLOTS
# =====================================

def plot_detailed_importance(results, num_samples=4, save_path=None):
    """
    Create detailed per-residue importance plots with structure annotations.
    """
    num_samples = min(num_samples, len(results))

    # Calculate figure height dynamically
    fig_height = max(10, num_samples * 2.8)
    fig = plt.figure(figsize=(18, fig_height))
    gs = GridSpec(num_samples, 1, figure=fig, hspace=0.35)

    # Color palette for lines
    colors = cm.get_cmap(COLORMAP_LINES)(np.linspace(0.2, 0.9, num_samples))

    for i in range(num_samples):
        ax = fig.add_subplot(gs[i])
        res = results[i]

        # Extract data
        imp = res['importance'][:res['valid_len']]
        y_true = res['y_true'][:res['valid_len']]
        y_pred = res['y_pred'][:res['valid_len']]
        positions = np.arange(len(imp))

        # Smooth importance for better visualization
        imp_smooth = gaussian_filter1d(imp, sigma=SMOOTH_SIGMA)

        # Plot structure background bands (predicted)
        for j in range(len(y_pred)):
            ss_type = int(y_pred[j])
            ax.axvspan(
                j - 0.5, j + 0.5,
                facecolor=SS_COLORS[ss_type]['light'],
                alpha=0.3,
                zorder=0
            )

        # Plot importance line
        ax.plot(
            positions, imp_smooth,
            color=colors[i],
            linewidth=2.5,
            label=f'Importance (smoothed σ={SMOOTH_SIGMA})',
            zorder=5
        )

        # Plot raw importance as scatter
        ax.scatter(
            positions, imp,
            c=imp,
            cmap=COLORMAP_HEATMAP,
            s=25,
            alpha=0.5,
            edgecolors='white',
            linewidths=0.5,
            zorder=6
        )

        # Highlight disagreements (prediction ≠ truth)
        disagreements = positions[y_pred[:res['valid_len']] != y_true[:res['valid_len']]]
        if len(disagreements) > 0:
            ax.scatter(
                disagreements,
                imp[disagreements],
                color='red',
                s=80,
                marker='x',
                linewidths=2,
                label=f'Mispredictions (n={len(disagreements)})',
                zorder=7
            )

        # Find and annotate top importance residues
        top_k = min(5, len(imp))
        top_indices = np.argsort(imp)[-top_k:][::-1]

        for rank, idx in enumerate(top_indices[:3]):  # Show top 3
            ax.annotate(
                f'#{rank+1}',
                xy=(idx, imp[idx]),
                xytext=(idx, imp[idx] + 0.12),
                fontsize=8,
                fontweight='bold',
                ha='center',
                bbox=dict(boxstyle='round,pad=0.3', facecolor='yellow',
                         alpha=0.7, edgecolor='orange'),
                arrowprops=dict(arrowstyle='->', color='orange', lw=1.5),
                zorder=8
            )

        # Styling
        ax.set_xlim(-1, res['valid_len'])
        ax.set_ylim(-0.05, 1.15)

        ax.set_ylabel(
            'Importance Score',
            fontsize=11,
            fontweight='bold'
        )

        ax.set_title(
            f"Sample #{res['idx']:03d} | Length: {res['valid_len']} | "
            f"Accuracy: {res['accuracy']:.1f}% | "
            f"Top Importance: {imp.max():.3f}",
            fontsize=11,
            fontweight='bold',
            pad=10
        )

        # Grid
        ax.grid(True, alpha=0.3, linestyle='--', linewidth=0.8)
        ax.set_axisbelow(True)

        # Legend
        ax.legend(loc='upper right', fontsize=9, framealpha=0.9)

        # Only show x-label on bottom plot
        if i == num_samples - 1:
            ax.set_xlabel('Residue Position', fontsize=12, fontweight='bold')

    # Super title
    fig.suptitle(
        'Per-Residue Importance Analysis with Secondary Structure Context',
        fontsize=15,
        fontweight='bold',
        y=0.995
    )

    plt.tight_layout(rect=[0, 0, 1, 0.99])

    if save_path:
        plt.savefig(save_path, dpi=300, bbox_inches='tight', facecolor='white')
        print(f"✓ Detail plots saved to {save_path}")

    plt.show()


# =====================================
# VISUALIZATION 3: STRUCTURE COMPARISON
# =====================================

def plot_structure_comparison(results, sample_idx=0, save_path=None):
    """
    Compare predicted vs true secondary structure with importance overlay.
    """
    res = results[sample_idx]

    fig = plt.figure(figsize=(18, 8))
    gs = GridSpec(3, 1, figure=fig, height_ratios=[1, 1, 1.5], hspace=0.3)

    # Extract data
    imp = res['importance'][:res['valid_len']]
    y_true = res['y_true'][:res['valid_len']]
    y_pred = res['y_pred'][:res['valid_len']]
    positions = np.arange(len(imp))

    # ---- Panel 1: True Structure ----
    ax1 = fig.add_subplot(gs[0])
    for j, ss in enumerate(y_true):
        ax1.add_patch(Rectangle(
            (j - 0.5, 0), 1, 1,
            facecolor=SS_COLORS[int(ss)]['color'],
            edgecolor='white',
            linewidth=0.5
        ))

    ax1.set_xlim(-0.5, len(y_true) - 0.5)
    ax1.set_ylim(0, 1)
    ax1.set_yticks([0.5])
    ax1.set_yticklabels(['True'], fontsize=11, fontweight='bold')
    ax1.set_title('True Secondary Structure', fontsize=12, fontweight='bold')
    ax1.set_xticks([])

    # ---- Panel 2: Predicted Structure ----
    ax2 = fig.add_subplot(gs[1])
    for j, ss in enumerate(y_pred):
        ax2.add_patch(Rectangle(
            (j - 0.5, 0), 1, 1,
            facecolor=SS_COLORS[int(ss)]['color'],
            edgecolor='white',
            linewidth=0.5
        ))

    # Mark errors
    errors = positions[y_pred != y_true]
    for err_pos in errors:
        ax2.add_patch(Rectangle(
            (err_pos - 0.5, 0), 1, 1,
            facecolor='none',
            edgecolor='red',
            linewidth=2.5
        ))

    ax2.set_xlim(-0.5, len(y_pred) - 0.5)
    ax2.set_ylim(0, 1)
    ax2.set_yticks([0.5])
    ax2.set_yticklabels(['Predicted'], fontsize=11, fontweight='bold')
    ax2.set_title(
        f'Predicted Secondary Structure (Errors: {len(errors)}, Accuracy: {res["accuracy"]:.1f}%)',
        fontsize=12,
        fontweight='bold'
    )
    ax2.set_xticks([])

    # ---- Panel 3: Importance Profile ----
    ax3 = fig.add_subplot(gs[2])

    # Background structure bands
    for j in range(len(y_pred)):
        ax3.axvspan(
            j - 0.5, j + 0.5,
            facecolor=SS_COLORS[int(y_pred[j])]['light'],
            alpha=0.25
        )

    # Importance area plot
    ax3.fill_between(
        positions, 0, imp,
        alpha=0.4,
        color='steelblue',
        label='Importance Profile'
    )

    # Importance line
    ax3.plot(
        positions, imp,
        color='darkblue',
        linewidth=2,
        label='Importance'
    )

    # Highlight error positions
    if len(errors) > 0:
        ax3.scatter(
            errors, imp[errors],
            color='red',
            s=100,
            marker='v',
            label='Misprediction Sites',
            zorder=10,
            edgecolors='darkred',
            linewidths=1.5
        )

    ax3.set_xlim(-0.5, len(imp) - 0.5)
    ax3.set_xlabel('Residue Position', fontsize=12, fontweight='bold')
    ax3.set_ylabel('Importance Score', fontsize=11, fontweight='bold')
    ax3.set_title('Residue Importance Profile', fontsize=12, fontweight='bold')
    ax3.grid(True, alpha=0.3, linestyle='--')
    ax3.legend(loc='upper right', fontsize=10, framealpha=0.9)

    # Overall title
    fig.suptitle(
        f'Structural Comparison and Importance Analysis - Sample #{res["idx"]:03d}',
        fontsize=15,
        fontweight='bold',
        y=0.98
    )

    # Add legend for structure colors
    legend_elements = [
        Rectangle((0, 0), 1, 1, fc=SS_COLORS[i]['color'],
                 label=SS_COLORS[i]['name'])
        for i in range(3)
    ]
    fig.legend(
        handles=legend_elements,
        loc='lower center',
        ncol=3,
        fontsize=10,
        frameon=True,
        fancybox=True,
        shadow=True
    )

    plt.tight_layout(rect=[0, 0.05, 1, 0.96])

    if save_path:
        plt.savefig(save_path, dpi=300, bbox_inches='tight', facecolor='white')
        print(f"✓ Comparison plot saved to {save_path}")

    plt.show()


# =====================================
# MAIN EXECUTION
# =====================================

def main():
    """
    Main execution function for residue importance analysis.
    """
    print("\n" + "="*70)
    print("INITIALIZING RESIDUE IMPORTANCE ANALYSIS")
    print("="*70 + "\n")

    # Compute importance scores
    results = analyze_residue_importance(
        SAMPLE_INDICES, model, val_ds, device
    )

    print("\n" + "="*70)
    print("GENERATING VISUALIZATIONS")
    print("="*70 + "\n")

    # Visualization 1: Heatmap Overview
    print("1. Creating heatmap overview...")
    plot_heatmap_overview(results)

    # Visualization 2: Detailed Line Plots
    print("\n2. Creating detailed importance plots...")
    plot_detailed_importance(results, num_samples=min(4, len(results)))

    # Visualization 3: Structure Comparison
    print("\n3. Creating structure comparison plot...")
    plot_structure_comparison(results, sample_idx=0)

    # Summary statistics
    print("\n" + "="*70)
    print("ANALYSIS SUMMARY")
    print("="*70)
    print(f"Total samples analyzed: {len(results)}")
    print(f"Average sequence length: {np.mean([r['valid_len'] for r in results]):.1f}")
    print(f"Average accuracy: {np.mean([r['accuracy'] for r in results]):.2f}%")
    print(f"Accuracy range: {min(r['accuracy'] for r in results):.1f}% - "
          f"{max(r['accuracy'] for r in results):.1f}%")

    # Top importance statistics
    all_importance = np.concatenate([r['importance'][:r['valid_len']] for r in results])
    print(f"\nImportance statistics:")
    print(f"  Mean: {all_importance.mean():.4f}")
    print(f"  Median: {np.median(all_importance):.4f}")
    print(f"  Std: {all_importance.std():.4f}")
    print(f"  95th percentile: {np.percentile(all_importance, 95):.4f}")

    print("\n" + "="*70)
    print("✓ ANALYSIS COMPLETE!")
    print("="*70 + "\n")

    return results


# =====================================
# EXECUTE
# =====================================

if __name__ == "__main__":
    results = main()

    # Optional: Save results
    # import pickle
