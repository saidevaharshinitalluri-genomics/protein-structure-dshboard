SAMPLE_INDEX_FOR_PLOTS = 0

# Get one sample from the validation dataset
X_sample_tensor, y_true_labels, mask_sample = val_ds[SAMPLE_INDEX_FOR_PLOTS]
L = int(mask_sample.sum().item()) # Actual length of the protein

# Move input to device and get model outputs
model.eval()
with torch.no_grad():
    X_input_for_model = X_sample_tensor.unsqueeze(0).to(device) # Add batch dimension
    # Get hidden states from GRU
    gru_output, _ = model.gru(X_input_for_model) # gru_output: (1, L_max, hidden_dim*2)
    hidden_states = gru_output.squeeze(0).cpu().numpy()[:L] # (L, hidden_dim*2)
    # Get logits and prediction probabilities
    logits = model.classifier(gru_output).squeeze(0) # (L_max, num_classes)
    pred_probs = torch.softmax(logits, dim=-1).cpu().numpy()[:L] # (L, num_classes)
    # Get predicted secondary structure labels
    ss_pred_indices = logits.argmax(dim=-1).cpu().numpy()[:L]

# Convert ss_pred indices to characters 'H', 'E', 'C' for plotting
# Based on target_names=['H','E','C'] where 0=H, 1=E, 2=C
def map_q3_indices_to_chars(q3_seq_indices):
    q3_chars = []
    for idx in q3_seq_indices:
        if idx == 0: q3_chars.append("H")
        elif idx == 1: q3_chars.append("E")
        elif idx == 2: q3_chars.append("C")
        else: q3_chars.append("?")
    return q3_chars

ss_pred = map_q3_indices_to_chars(ss_pred_indices)

# Physico-chemical features: extract from X_fused
# The AA_PROPERTIES (6 features) were appended as the last 6 columns to the original D=57 features.
# So, they are columns INPUT_DIM - AA_PROP_DIM to INPUT_DIM.
# INPUT_DIM = 63, AA_PROP_DIM = 6. So physchem features are columns 57-62.
physio = X_sample_tensor[:, (INPUT_DIM - AA_PROP_DIM):INPUT_DIM].cpu().numpy()[:L]
# Ensure physio has at least 3 columns for hydro, charge, mass. Pad with zeros if less.
if physio.shape[1] < 3:
    physio_padded = np.zeros((L, 3), dtype=np.float32)
    physio_padded[:, :physio.shape[1]] = physio
    physio = physio_padded

# Dummy PSSM and Attention (not available in the current model/dataset structure)
pssm = np.random.rand(L, 20) # Dummy data for PSSM, expected shape (L, 20)
attn = np.random.rand(L)     # Dummy data for attention weights, expected shape (L,)


#########################################
# 1. Evolutionary Conservation Plot
#########################################

conservation = pssm.mean(axis=1)
plt.figure(figsize=(14,4))
plt.plot(conservation, linewidth=2)
for i in range(len(ss_pred)):
    if ss_pred[i] == "H":
        plt.axvspan(i, i+1, color='red', alpha=0.25)
    elif ss_pred[i] == "E":
        plt.axvspan(i, i+1, color='gold', alpha=0.25)
plt.title("Residue Conservation Profile with Predicted Structural Elements")
plt.xlabel("Residue Index")
plt.ylabel("Conservation (PSSM mean)")
plt.show()


#########################################
# 2. Attention × Biochemical Property Map
#########################################

hydro = physio[:, 0]   # assume column 0 = hydrophobicity
charge = physio[:, 1]  # assume column 1 = charge
mass  = physio[:, 2]   # assume column 2 = mass (or molecular weight as per AA_PROPERTIES)

mat = np.vstack([attn, hydro, charge, mass])

plt.figure(figsize=(14,3))
plt.imshow(mat, aspect='auto', cmap='viridis')
plt.yticks([0,1,2,3], ["Attention", "Hydrophobicity", "Molecular Weight", "pI"])
plt.colorbar(label="Normalized value")
plt.title("Biochemical Profile × Attention Map")
plt.show()


#########################################
# 3. Structural Element Length Distribution
#########################################

def lengths_of(type_char):
    lengths = []
    count = 0
    for x in ss_pred:
        if x == type_char:
            count += 1
        else:
            if count > 0:
                lengths.append(count)
                count = 0
    if count > 0: # Add the last segment if loop ends with current type_char
        lengths.append(count)
    return lengths

helix_len = lengths_of("H")
sheet_len = lengths_of("E")
coil_len  = lengths_of("C")



#########################################
# 5. Energy-like Folding Landscape
#########################################

prob = np.max(pred_probs, axis=1)
energy = -np.log(prob + 1e-8)
energy_smooth = gaussian_filter1d(energy, sigma=3)

plt.figure(figsize=(14,4))
plt.plot(energy_smooth, linewidth=2)
plt.fill_between(range(len(energy_smooth)), energy_smooth, alpha=0.25)
plt.title("Model-Derived Folding Energy Landscape (Smoothed)")
plt.xlabel("Residue Index")
plt.ylabel("Energy (−log probability)")
plt.show()

# Save final model
torch.save(model.state_dict(), 'gru_fusion_cb513_final.pth')
print('Saved gru_fusion_cb513_final.pth')

